@inherits JsInteropableComponent

<div class="h-100 @(OuterClass)">
  <input @ref="_virtualKeyboard" class="virtual-keyboard" type="text" autocomplete="off" autocapitalize="off"
    @onblur="HandleVirtualKeyboardBlurred" @bind-value="VirtualKeyboardText" @bind-value:event="oninput"
    @onkeydown="OnVkKeyDown" />

  <div class="display-grid">
    <div class="action-bar pa-2">

      <PopoverButton Icon="@(Icons.Material.Filled.ScreenshotMonitor)" Label="View" TooltipText="View">
        <ViewPopover />
      </PopoverButton>

      <PopoverButton Icon="@(Icons.Material.Filled.Keyboard)" Label="Input" TooltipText="Input">
        <InputPopover />
      </PopoverButton>
      
      <PopoverButton Icon="@(Icons.Material.Filled.MoreVert)" Label="Extras" TooltipText="Extras">
        <ExtrasPopover />
      </PopoverButton>

      <MudDivider Vertical FlexItem />

      <MudTooltip Text="Annotate" Placement="Placement.Right" Class="z9002">
        <MudToggleIconButton Variant="Variant.Outlined" Icon="@(Icons.Material.Filled.Draw)" Size="Size.Small"
          ToggledColor="Color.Warning" ToggledIcon="@(Icons.Material.Filled.Draw)"
          Toggled="_isAnnotationMode" ToggledChanged="HandleAnnotationModeToggled" />
      </MudTooltip>

      <MudTooltip Text="Toggle Audio" Placement="Placement.Right" Class="z9002">
        <MudToggleIconButton Variant="Variant.Outlined" Icon="@(Icons.Material.Filled.VolumeOff)" Size="Size.Small"
          ToggledColor="Color.Success" ToggledIcon="@(Icons.Material.Filled.VolumeUp)"
          Toggled="_isAudioEnabled" ToggledChanged="HandleAudioToggled" />
      </MudTooltip>

      <MudTooltip Text="Toggle Webcam" Placement="Placement.Right" Class="z9002">
        <MudToggleIconButton Variant="Variant.Outlined" Icon="@(Icons.Material.Filled.VideocamOff)" Size="Size.Small"
          ToggledColor="Color.Success" ToggledIcon="@(Icons.Material.Filled.Videocam)"
          Toggled="_isWebcamEnabled" ToggledChanged="HandleWebcamToggled" />
      </MudTooltip>

      @if (_controlMode == ControlMode.Touch)
      {
        <MudDivider Vertical FlexItem />

        <MudTooltip Text="Virtual Keyboard" Placement="Placement.Right" Class="z9002">
          <MudToggleIconButton Variant="Variant.Outlined" Icon="@(Icons.Material.Filled.KeyboardHide)" Size="Size.Small"
            ToggledColor="Color.Success" ToggledIcon="@(Icons.Material.Filled.KeyboardHide)"
            Toggled="RemoteControlState.IsVirtualKeyboardToggled" ToggledChanged="HandleKeyboardToggled" />
        </MudTooltip>

        <MudTooltip Text="Scroll Mode" Placement="Placement.Right" Class="z9002">
          <MudToggleIconButton Variant="Variant.Outlined" Icon="@(Icons.Material.Filled.UnfoldMoreDouble)"
            Size="Size.Small" ToggledColor="Color.Success" ToggledIcon="@(Icons.Material.Filled.UnfoldMoreDouble)"
            Toggled="RemoteControlState.IsScrollModeToggled" ToggledChanged="HandleScrollModeToggled" />
        </MudTooltip>
      }

      <MudFlexBreak />

      <ConnectionQualityIndicator />

      <MudTooltip Text="Toggle Fullscreen" Placement="Placement.Left" Class="z9002">
        <MudIconButton Icon="@(Icons.Material.Filled.Fullscreen)" Variant="Variant.Outlined" Size="Size.Small"
          OnClick="HandleFullscreenClicked" />
      </MudTooltip>

      <MudTooltip Text="Close Connection" Placement="Placement.Right" Class="z9002">
        <MudIconButton Icon="@(Icons.Material.Filled.Close)" Variant="Variant.Outlined" Size="Size.Small"
          Color="Color.Error" OnClick="HandleDisconnectClicked" />
      </MudTooltip>

    </div>
    <div class="screen-area" 
         @ref="_screenArea" 
         @onwheel="HandleScreenAreaCanvasWheel"
         @onwheel:preventDefault
         @onwheel:stopPropagation 
         @ontouchstart="HandleScreenAreaTouchStart" 
         @ontouchmove="HandleScreenAreaTouchMove" 
         @ontouchcancel="HandleScreenAreaTouchCancel"
         @ontouchend="HandleScreenAreaTouchEnd">

      <canvas id="@_canvasId" @ref="_canvasRef"
              width="@CanvasWidth" height="@CanvasHeight"
              class='@($"remote-screen {CanvasClasses}")' style="@(CanvasStyle)"
              @onpointermove="HandleCanvasPointerMove"
              @onpointerdown="HandleCanvasPointerDown">
      </canvas>

      <AnnotationCanvas IsActive="_isAnnotationMode"
                        CanvasWidth="CanvasWidth"
                        CanvasHeight="CanvasHeight"
                        CanvasStyle="@(AnnotationCanvasStyle)" />

      @if (_isWebcamEnabled)
      {
        <div class="webcam-pip @(_webcamPipSize)" @ref="_webcamPipRef">
          <div class="webcam-pip-header"
               @onpointerdown="HandleWebcamPipPointerDown"
               @onpointerdown:stopPropagation
               @onpointermove="HandleWebcamPipPointerMove"
               @onpointermove:stopPropagation
               @onpointerup="HandleWebcamPipPointerUp"
               @onpointerup:stopPropagation>
            <MudIconButton Icon="@(_webcamPipSize == "pip-large" ? Icons.Material.Filled.CloseFullscreen : Icons.Material.Filled.OpenInFull)"
              Size="Size.Small" Class="webcam-pip-btn" OnClick="HandleWebcamPipResize" />
            <MudIconButton Icon="@Icons.Material.Filled.Close"
              Size="Size.Small" Class="webcam-pip-btn" Color="Color.Error" OnClick="HandleWebcamPipClose" />
          </div>
          @if (!string.IsNullOrEmpty(_webcamImageDataUri))
          {
            <img src="@_webcamImageDataUri" alt="Webcam" class="webcam-pip-image" />
          }
          else
          {
            <div class="webcam-pip-placeholder">
              <MudProgressCircular Indeterminate Size="Size.Small" Color="Color.Info" />
              <MudText Typo="Typo.caption" Class="mt-1">Connecting camera...</MudText>
            </div>
          }
        </div>
      }
    </div>
  </div>

  @if (RemoteControlState.IsMetricsEnabled)
  {
    <MetricsFrame />
  }

</div>