@implements IDisposable

@inject AuthenticationStateProvider AuthState
@inject NavigationManager NavMan
@inject ILogger<NavMenu> Logger
@inject IPublicRegistrationSettingsProvider PublicRegistingsProvider
@inject ISnackbar Snackbar
@inject ILazyInjector<IControlrApi> ControlrApi
@inject ITenantSwitcherService TenantSwitcher

<MudNavMenu>
  <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
    Home
  </MudNavLink>
  <AuthorizeView Roles="@RoleNames.ClientUser">
    <Authorized>
      <MudNavLink Href="@(ClientRoutes.ClientDashboard)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Devices">
        My Devices
      </MudNavLink>
    </Authorized>
  </AuthorizeView>
  <AuthorizeView Roles="@RoleNames.ClientUser">
    <NotAuthorized>
      <MudNavLink Disabled="!_isAuthenticated" Href="@(ClientRoutes.Deploy)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RocketLaunch">
        Deploy
      </MudNavLink>
    </NotAuthorized>
  </AuthorizeView>
  <AuthorizeView Roles="@($"{RoleNames.TenantAdministrator}, {RoleNames.InstallerKeyManager}")">
    <MudNavLink Disabled="!_isAuthenticated" Href="@(ClientRoutes.InstallerKeys)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.InstallDesktop">
      Installer Keys
    </MudNavLink>
  </AuthorizeView>
  <MudNavLink Disabled="!_isAuthenticated" Href="@(ClientRoutes.PersonalAccessTokens)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Key">
    Access Tokens
  </MudNavLink>
  <MudNavLink Disabled="!_isAuthenticated" Href="@(ClientRoutes.Settings)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">
    Settings
  </MudNavLink>

  <MudNavLink Href="@(ClientRoutes.About)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QuestionMark">
    About
  </MudNavLink>

  <AuthorizeView Roles="@($"{RoleNames.TenantAdministrator}")">
    <div class="nav-section-label">
      <MudText Typo="Typo.overline" Color="Color.Tertiary">
        Tenant Admin
      </MudText>
    </div>

    <MudNavGroup Title="Organization" Icon="@Icons.Material.Filled.Business" @bind-Expanded="_orgExpanded">
      <MudNavLink Href="@(ClientRoutes.ClientsManagement)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
        Client Management
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.DeviceGroups)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FolderSpecial">
        Device Groups
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Permissions)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SupervisedUserCircle">
        Permissions
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Invite)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Email">
        Invite
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.TenantSettings)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">
        Tenant Settings
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Branding)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Palette">
        Branding
      </MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Automation" Icon="@Icons.Material.Filled.AutoMode" @bind-Expanded="_autoExpanded">
      <MudNavLink Href="@(ClientRoutes.Scripts)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Code">
        Scripts
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.ScheduledTasks)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schedule">
        Scheduled Tasks
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Monitoring)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">
        Monitoring
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.AlertRules)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.NotificationsActive">
        Alert Rules
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Suggestions)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AutoAwesome">
        Suggestions
      </MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Operations" Icon="@Icons.Material.Filled.Engineering" @bind-Expanded="_opsExpanded">
      <MudNavLink Href="@(ClientRoutes.AssetManagement)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory">
        Asset Management
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.PatchManagement)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SystemUpdateAlt">
        Patch Management
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Toolbox)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.BuildCircle">
        Toolbox
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.AuditLog)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">
        Audit Log
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Webhooks)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Webhook">
        Webhooks
      </MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Support" Icon="@Icons.Material.Filled.SupportAgent" @bind-Expanded="_supportExpanded">
      <MudNavLink Href="@(ClientRoutes.SupportSessions)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Support">
        Support Sessions
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.SessionRecordings)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.VideoLibrary">
        Session Recordings
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Ticketing)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ConfirmationNumber">
        Ticketing
      </MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Security" Icon="@Icons.Material.Filled.Security" @bind-Expanded="_secExpanded">
      <MudNavLink Href="@(ClientRoutes.Credentials)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.VpnKey">
        Credential Vault
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.JitAdmin)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings">
        JIT Admin
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.Plugins)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Extension">
        Plugins
      </MudNavLink>
    </MudNavGroup>
  </AuthorizeView>

  <AuthorizeView Roles="@(RoleNames.ServerAdministrator)">
    <Authorized>
      <div class="nav-section-label">
        <MudText Typo="Typo.overline" Color="Color.Tertiary">
          Server Admin
        </MudText>
      </div>
      @if (_tenants is not null)
      {
        <div class="mx-2 my-2">
          <MudSelect T="Guid?" Value="_selectedTenantId" ValueChanged="OnTenantSelected"
            Label="Tenant Context" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
            <MudSelectItem T="Guid?" Value="@((Guid?)null)">All Tenants (MSP)</MudSelectItem>
            @foreach (var tenant in _tenants)
            {
              <MudSelectItem T="Guid?" Value="@((Guid?)tenant.Id)">@tenant.Name</MudSelectItem>
            }
          </MudSelect>
        </div>
      }
      <MudNavLink Href="@(ClientRoutes.ServerSettings)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">
        Server Settings
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.ServerStats)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings">
        Server Stats
      </MudNavLink>
      <MudNavLink Href="@(ClientRoutes.ServerLogs)" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TextSnippet">
        Server Logs
      </MudNavLink>
    </Authorized>
  </AuthorizeView>

  <MudDivider Class="mt-2 mb-2" />

  <AuthorizeView>
    <Authorized>
      <MudNavLink Href="Account/Manage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">
        Account
      </MudNavLink>
      @if (RendererInfo.IsInteractive && OperatingSystem.IsBrowser())
      {
        <button type="button" class="mud-nav-link mud-ripple" @onclick="HandleLogoutClicked">
          <MudIcon Icon="@Icons.Material.Filled.Logout" Color="Color.Info" Class="mr-3"></MudIcon> Logout
        </button>
      }
      else
      {
        <form action="Account/Logout" method="post">
          <AntiforgeryToken />
          <input type="hidden" name="ReturnUrl" value="@_currentUrl" />
          <button type="submit" class="mud-nav-link mud-ripple">
            <MudIcon Icon="@Icons.Material.Filled.Logout" Color="Color.Info" Class="mr-3"></MudIcon> Logout
          </button>
        </form>
      }
    </Authorized>
    <NotAuthorized>
      @if (_isPublicRegistrationEnabled)
      {
        <MudNavLink Href="Account/Register" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">
          Register
        </MudNavLink>
      }
      <MudNavLink Href="Account/Login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Password">
        Login
      </MudNavLink>
    </NotAuthorized>
  </AuthorizeView>
</MudNavMenu>

<style>
  .nav-section-label {
    padding: 16px 16px 4px 16px;
    letter-spacing: 0.1em;
  }
</style>

@code {

  private string? _currentUrl;
  private bool _isAuthenticated;
  private bool _isPublicRegistrationEnabled;
  private TenantResponseDto[]? _tenants;
  private Guid? _selectedTenantId;

  private bool _orgExpanded;
  private bool _autoExpanded;
  private bool _opsExpanded;
  private bool _supportExpanded;
  private bool _secExpanded;

  public void Dispose()
  {
    NavMan.LocationChanged -= OnLocationChanged;
    AuthState.AuthenticationStateChanged -= HandleAuthStateChanged;
  }

  protected override async Task OnInitializedAsync()
  {
    await base.OnInitializedAsync();

    _isPublicRegistrationEnabled = await PublicRegistingsProvider.GetIsPublicRegistrationEnabled();

    var state = await AuthState.GetAuthenticationStateAsync();
    _isAuthenticated = state.User.IsAuthenticated();

    if (state.User.IsInRole(RoleNames.ServerAdministrator))
    {
      _ = LoadTenants();
    }

    AuthState.AuthenticationStateChanged += HandleAuthStateChanged;
    _currentUrl = NavMan.ToBaseRelativePath(NavMan.Uri);
    NavMan.LocationChanged += OnLocationChanged;
  }

  private async void HandleAuthStateChanged(Task<AuthenticationState> stateTask)
  {
    try
    {
      var state = await stateTask;
      _isAuthenticated = state.User.IsAuthenticated();
      await InvokeAsync(StateHasChanged);
    }
    catch (Exception ex)
    {
      Logger.LogError(ex, "Error while handling auth state change.");
    }
  }

  private async Task HandleLogoutClicked()
  {
    if (!RendererInfo.IsInteractive)
    {
      return;
    }

    var result = await ControlrApi.Value.LogOut();
    if (!result.IsSuccess) {
      Snackbar.Add("Logout failed", Severity.Error);
      return;
    }

    NavMan.NavigateTo("/", true);
  }

  private async Task LoadTenants()
  {
    var result = await ControlrApi.Value.GetAllTenants();
    if (result.IsSuccess)
    {
      _tenants = result.Value;
      await InvokeAsync(StateHasChanged);
    }
  }

  private void OnTenantSelected(Guid? tenantId)
  {
    _selectedTenantId = tenantId;
    if (tenantId is null)
    {
      TenantSwitcher.ClearOverride();
    }
    else
    {
      var tenant = _tenants?.FirstOrDefault(t => t.Id == tenantId);
      TenantSwitcher.SwitchTenant(tenantId, tenant?.Name);
    }

    NavMan.NavigateTo("/", forceLoad: false);
  }

  private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
  {
    _currentUrl = NavMan.ToBaseRelativePath(e.Location);
    StateHasChanged();
  }
}
