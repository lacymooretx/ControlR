@inject IControlrApi ControlrApi
@inject ISnackbar Snackbar

<MudDialog>
  <DialogContent>
    <MudForm @ref="_form">
      <MudTextField @bind-Value="_name" Label="Name" Required RequiredError="Name is required"
        Class="mb-3" Placeholder="e.g. Domain Admin, Local Admin" />
      <MudTextField @bind-Value="_description" Label="Description" Lines="2" Class="mb-3"
        Placeholder="Optional description for this credential" />
      <MudTextField @bind-Value="_username" Label="Username" Required RequiredError="Username is required"
        Class="mb-3" />
      <MudTextField @bind-Value="_password" Label="Password"
        InputType="@(_showPassword ? InputType.Text : InputType.Password)"
        Adornment="Adornment.End"
        AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
        OnAdornmentClick="TogglePasswordVisibility"
        Required="@(ExistingCredential is null)"
        RequiredError="Password is required"
        HelperText="@(ExistingCredential is not null ? "Leave blank to keep existing password" : "")"
        Class="mb-3" />
      <MudTextField @bind-Value="_domain" Label="Domain" Class="mb-3"
        Placeholder="Optional domain (e.g. CONTOSO)" />
      <MudTextField @bind-Value="_category" Label="Category" Class="mb-3"
        Placeholder="Optional category (e.g. Server, Workstation, Network)" />
      <MudDivider Class="my-3" />
      <MudText Typo="Typo.subtitle2" Class="mb-2">Scope</MudText>
      <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mb-2">
        Leave both fields empty for tenant-wide credentials. Set a Device ID or Group ID to restrict scope.
      </MudText>
      <MudTextField @bind-Value="_deviceIdText" Label="Device ID (GUID)" Class="mb-3"
        Placeholder="Optional - scope to specific device" />
      <MudTextField @bind-Value="_deviceGroupIdText" Label="Device Group ID (GUID)" Class="mb-3"
        Placeholder="Optional - scope to device group" />
    </MudForm>
  </DialogContent>
  <DialogActions>
    <MudButton OnClick="Cancel">Cancel</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
      Disabled="_saving">
      @if (_saving)
      {
        <MudProgressCircular Indeterminate Size="Size.Small" Class="mr-2" />
      }
      Save
    </MudButton>
  </DialogActions>
</MudDialog>

@code {
  [CascadingParameter]
  private IMudDialogInstance MudDialog { get; set; } = null!;

  [Parameter]
  public StoredCredentialDto? ExistingCredential { get; set; }

  private MudForm _form = null!;
  private string _name = string.Empty;
  private string _description = string.Empty;
  private string _username = string.Empty;
  private string _password = string.Empty;
  private string _domain = string.Empty;
  private string _category = string.Empty;
  private string _deviceIdText = string.Empty;
  private string _deviceGroupIdText = string.Empty;
  private bool _showPassword;
  private bool _saving;

  protected override void OnInitialized()
  {
    if (ExistingCredential is not null)
    {
      _name = ExistingCredential.Name;
      _description = ExistingCredential.Description ?? string.Empty;
      _username = ExistingCredential.Username;
      _domain = ExistingCredential.Domain ?? string.Empty;
      _category = ExistingCredential.Category ?? string.Empty;
      _deviceIdText = ExistingCredential.DeviceId?.ToString() ?? string.Empty;
      _deviceGroupIdText = ExistingCredential.DeviceGroupId?.ToString() ?? string.Empty;
    }
  }

  private void TogglePasswordVisibility() => _showPassword = !_showPassword;

  private void Cancel() => MudDialog.Cancel();

  private async Task Save()
  {
    await _form.Validate();
    if (!_form.IsValid)
    {
      return;
    }

    Guid? deviceId = null;
    if (!string.IsNullOrWhiteSpace(_deviceIdText))
    {
      if (!Guid.TryParse(_deviceIdText, out var parsed))
      {
        Snackbar.Add("Device ID must be a valid GUID.", Severity.Error);
        return;
      }
      deviceId = parsed;
    }

    Guid? deviceGroupId = null;
    if (!string.IsNullOrWhiteSpace(_deviceGroupIdText))
    {
      if (!Guid.TryParse(_deviceGroupIdText, out var parsed))
      {
        Snackbar.Add("Device Group ID must be a valid GUID.", Severity.Error);
        return;
      }
      deviceGroupId = parsed;
    }

    _saving = true;

    if (ExistingCredential is not null)
    {
      var request = new UpdateCredentialRequestDto(
        ExistingCredential.Id,
        _name,
        string.IsNullOrWhiteSpace(_description) ? null : _description,
        _username,
        string.IsNullOrEmpty(_password) ? null : _password,
        string.IsNullOrWhiteSpace(_domain) ? null : _domain,
        deviceId,
        deviceGroupId,
        string.IsNullOrWhiteSpace(_category) ? null : _category);

      var result = await ControlrApi.UpdateCredential(ExistingCredential.Id, request);
      if (!result.IsSuccess)
      {
        Snackbar.Add(result.Reason, Severity.Error);
        _saving = false;
        return;
      }

      Snackbar.Add("Credential updated.", Severity.Success);
    }
    else
    {
      if (string.IsNullOrEmpty(_password))
      {
        Snackbar.Add("Password is required for new credentials.", Severity.Error);
        _saving = false;
        return;
      }

      var request = new CreateCredentialRequestDto(
        _name,
        string.IsNullOrWhiteSpace(_description) ? null : _description,
        _username,
        _password,
        string.IsNullOrWhiteSpace(_domain) ? null : _domain,
        deviceId,
        deviceGroupId,
        string.IsNullOrWhiteSpace(_category) ? null : _category);

      var result = await ControlrApi.CreateCredential(request);
      if (!result.IsSuccess)
      {
        Snackbar.Add(result.Reason, Severity.Error);
        _saving = false;
        return;
      }

      Snackbar.Add("Credential created.", Severity.Success);
    }

    _saving = false;
    MudDialog.Close(DialogResult.Ok(true));
  }
}
