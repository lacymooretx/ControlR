@attribute [Route(ClientRoutes.TenantSettings)]
@attribute [Authorize(Roles = RoleNames.TenantAdministrator)]

@inject ITenantSettingsProvider TenantSettingsProvider
@inject ISnackbar Snackbar

<PageTitle>
  Tenant Settings
</PageTitle>

<PrimaryTitle>
  Tenant Settings
</PrimaryTitle>

<div class="mt-10">
  <MudText Typo="Typo.h6" Color="Color.Primary" GutterBottom>
    Show Notification to User
  </MudText>
  <MudText Typo="Typo.body2" Class="mb-3">
    Controls whether users receive notifications when remote control sessions start.
  </MudText>
  
  <MudRadioGroup T="bool?" Value="_notifyUser" ValueChanged="SetNotifyUser">
    <MudRadio T="bool?" Value="@((bool?)null)" Color="Color.Primary">
      Use individual account setting
    </MudRadio>
    <MudRadio T="bool?" Value="@((bool?)true)" Color="Color.Primary">
      Always notify users
    </MudRadio>
    <MudRadio T="bool?" Value="@((bool?)false)" Color="Color.Primary">
      Never notify users
    </MudRadio>
  </MudRadioGroup>
</div>

<div class="mt-10">
  <MudText Typo="Typo.h6" Color="Color.Primary" GutterBottom>
    Two-Factor Authentication
  </MudText>
  <MudText Typo="Typo.body2" Class="mb-3">
    When enabled, all users in this tenant must configure TOTP-based two-factor authentication.
    Users without 2FA will be redirected to the setup page on login.
    PAT and logon token authentication are exempt.
  </MudText>

  <MudSwitch T="bool" Value="_requireTotp" ValueChanged="SetRequireTotp" Color="Color.Primary"
    Label="@(_requireTotp ? "Required" : "Optional")" />
</div>

@code {
  private bool? _notifyUser;
  private bool _requireTotp;

  protected override async Task OnInitializedAsync()
  {
    _notifyUser = await TenantSettingsProvider.GetNotifyUserOnSessionStart();
    _requireTotp = await TenantSettingsProvider.GetRequireTotp();
    await base.OnInitializedAsync();
  }

  private async Task SetNotifyUser(bool? value)
  {
    _notifyUser = value;
    await TenantSettingsProvider.SetNotifyUserOnSessionStart(value);
    Snackbar.Add("Setting updated", Severity.Success);
  }

  private async Task SetRequireTotp(bool value)
  {
    _requireTotp = value;
    await TenantSettingsProvider.SetRequireTotp(value);
    Snackbar.Add("Setting updated", Severity.Success);
  }
}