@page "/credentials"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = RoleNames.TenantAdministrator)]
@inject ILazyInjector<IControlrApi> ControlrApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime

<MudText Typo="Typo.h4" Color="Color.Primary" GutterBottom>
  Credential Vault
</MudText>

<MudPaper Class="pa-4 mb-4">
  <MudStack Row AlignItems="AlignItems.Center">
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
      StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
      Add Credential
    </MudButton>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Info"
      OnClick="RefreshCredentials" />
  </MudStack>
</MudPaper>

@if (_loading)
{
  <MudProgressLinear Indeterminate Color="Color.Primary" />
}
else if (_credentials.Count == 0)
{
  <MudAlert Severity="Severity.Info">
    No credentials stored. Add credentials to the vault for quick authentication during remote sessions.
  </MudAlert>
}
else
{
  <MudDataGrid T="StoredCredentialDto" Items="_credentials" SortMode="SortMode.Single"
    Filterable="false" Hideable="false">
    <Columns>
      <PropertyColumn Property="x => x.Name" Title="Name" />
      <PropertyColumn Property="x => x.Username" Title="Username" />
      <PropertyColumn Property="x => x.Domain" Title="Domain" />
      <TemplateColumn T="StoredCredentialDto" Title="Scope" Sortable="false">
        <CellTemplate>
          @GetScopeDisplay(context.Item)
        </CellTemplate>
      </TemplateColumn>
      <PropertyColumn Property="x => x.Category" Title="Category" />
      <TemplateColumn T="StoredCredentialDto" Title="Last Accessed" Sortable="true" SortBy="x => x.LastAccessedAt">
        <CellTemplate>
          @(context.Item.LastAccessedAt?.ToString("g") ?? "Never")
        </CellTemplate>
      </TemplateColumn>
      <PropertyColumn Property="x => x.AccessCount" Title="Access Count" />
      <TemplateColumn T="StoredCredentialDto" Title="Actions" Sortable="false">
        <CellTemplate>
          @{
            var cred = context.Item;
          }
          <MudStack Row>
            <MudTooltip Text="Copy password to clipboard (audit-logged)">
              <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Warning"
                Size="Size.Small"
                OnClick="@(() => RetrievePassword(cred))" />
            </MudTooltip>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
              Size="Size.Small" title="Edit"
              OnClick="@(() => OpenEditDialog(cred))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
              Size="Size.Small" title="Delete"
              OnClick="@(() => DeleteCredential(cred))" />
          </MudStack>
        </CellTemplate>
      </TemplateColumn>
    </Columns>
  </MudDataGrid>
}

@code {
  private bool _loading = true;
  private List<StoredCredentialDto> _credentials = [];

  protected override async Task OnInitializedAsync()
  {
    await RefreshCredentials();
  }

  private async Task RefreshCredentials()
  {
    _loading = true;
    StateHasChanged();

    var result = await ControlrApi.Value.GetAllCredentials();
    if (result.IsSuccess)
    {
      _credentials = result.Value.ToList();
    }
    else
    {
      Snackbar.Add($"Failed to load credentials: {result.Reason}", Severity.Error);
    }

    _loading = false;
  }

  private async Task OpenCreateDialog()
  {
    var options = new DialogOptions
    {
      MaxWidth = MaxWidth.Small,
      FullWidth = true,
      CloseOnEscapeKey = true
    };

    var dialog = await DialogService.ShowAsync<CredentialEditDialog>("Add Credential", options);
    var dialogResult = await dialog.Result;

    if (dialogResult is not null && !dialogResult.Canceled)
    {
      await RefreshCredentials();
    }
  }

  private async Task OpenEditDialog(StoredCredentialDto credential)
  {
    var parameters = new DialogParameters<CredentialEditDialog>
    {
      { x => x.ExistingCredential, credential },
    };

    var options = new DialogOptions
    {
      MaxWidth = MaxWidth.Small,
      FullWidth = true,
      CloseOnEscapeKey = true
    };

    var dialog = await DialogService.ShowAsync<CredentialEditDialog>("Edit Credential", parameters, options);
    var dialogResult = await dialog.Result;

    if (dialogResult is not null && !dialogResult.Canceled)
    {
      await RefreshCredentials();
    }
  }

  private async Task RetrievePassword(StoredCredentialDto credential)
  {
    var confirmed = await DialogService.ShowMessageBox(
      "Retrieve Password",
      $"Retrieving the password for \"{credential.Name}\" will be recorded in the audit log. Continue?",
      "Retrieve", "Cancel");

    if (confirmed != true)
    {
      return;
    }

    var result = await ControlrApi.Value.RetrieveCredentialPassword(credential.Id);
    if (result.IsSuccess)
    {
      try
      {
        await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", result.Value.Password);
        Snackbar.Add("Password copied to clipboard.", Severity.Success);
      }
      catch
      {
        Snackbar.Add("Password retrieved but clipboard access was denied by the browser.", Severity.Warning);
      }

      // Refresh to update access count/timestamp
      await RefreshCredentials();
    }
    else
    {
      Snackbar.Add($"Failed to retrieve password: {result.Reason}", Severity.Error);
    }
  }

  private async Task DeleteCredential(StoredCredentialDto credential)
  {
    var confirmed = await DialogService.ShowMessageBox(
      "Delete Credential",
      $"Are you sure you want to delete \"{credential.Name}\"? This action cannot be undone.",
      "Delete", "Cancel");

    if (confirmed != true)
    {
      return;
    }

    var result = await ControlrApi.Value.DeleteCredential(credential.Id);
    if (result.IsSuccess)
    {
      Snackbar.Add("Credential deleted.", Severity.Success);
      await RefreshCredentials();
    }
    else
    {
      Snackbar.Add($"Failed to delete credential: {result.Reason}", Severity.Error);
    }
  }

  private static string GetScopeDisplay(StoredCredentialDto credential)
  {
    if (credential.DeviceId.HasValue)
    {
      return "Device-specific";
    }
    if (credential.DeviceGroupId.HasValue)
    {
      return "Group-scoped";
    }
    return "Tenant-wide";
  }
}
